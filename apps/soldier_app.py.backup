# ═══════════════════════════════════════════════════════════
#  SOLDIER CARD - Simple data model
# ═══════════════════════════════════════════════════════════

class SoldierCard:
    """
    Soldier card memory layout:
    ┌─────────┬──────────────────────────────────────────────┐
    │ Block 4 │ Soldier ID (16 bytes)                        │
    │ Block 5 │ Card Type "SOLDIER" (16 bytes)               │
    └─────────┴──────────────────────────────────────────────┘
    
    Baki sab info DATABASE se aati hai via Soldier ID lookup:
      - Soldier Name
      - Conductor Name + ID
      - Unit Name
      - Required Cargo (items list)
    """

    def __init__(self):
        self.soldier_id = ""
        self.card_type  = "SOLDIER"

    def write(self, core):
        if not core.authenticate(1):
            raise Exception("Auth failed - Sector 1")
        core.write_block(4, core.encode(self.soldier_id, 16))
        core.write_block(5, core.encode(self.card_type, 16))
        return True

    def read(self, core):
        if not core.authenticate(1):
            raise Exception("Auth failed - Sector 1")
        b4 = core.read_block(4)
        if b4:
            self.soldier_id = core.decode(b4)
        b5 = core.read_block(5)
        if b5:
            self.card_type = core.decode(b5)


# ═══════════════════════════════════════════════════════════
#  MAIN APP
# ═══════════════════════════════════════════════════════════

class SoldierApp:

    def __init__(self, root):
        self.root = root
        self.root.title("Soldier Card Management — Army Logistics")
        self.root.configure(bg=COLORS["bg"])
        self.root.geometry("1400x800")
        self.root.minsize(1200, 700)
        try:
            self.root.state("zoomed")
        except Exception:
            pass

        # Initialize
        self.db = DatabaseHelper()
        self.mifare = MifareCore(self._log)
        self.selected_soldier = None
        self.card_present = False

        # Test DB connection
        success, msg = self.db.test_connection()
        if not success:
            messagebox.showerror(
                "Database Error",
                f"Cannot connect to database!\n\n{msg}"
            )
            self.root.destroy()
            return

        self._setup_styles()
        self._build_ui()
        self._load_soldiers()

        # Start card polling
        self.mifare.find_reader()
        self._poll_card()

    def _setup_styles(self):
        s = ttk.Style()
        s.theme_use("clam")
        s.configure(
            "Custom.Treeview",
            background=COLORS["white"],
            foreground=COLORS["text"],
            rowheight=30,
            fieldbackground=COLORS["white"],
            font=FONTS["body"],
            borderwidth=0
        )
        s.configure(
            "Custom.Treeview.Heading",
            background=COLORS["primary"],
            foreground="white",
            font=FONTS["title"]
        )
        s.map("Custom.Treeview",
              background=[("selected", COLORS["secondary"])],
              foreground=[("selected", "white")])

        # Cargo treeview (smaller)
        s.configure(
            "Cargo.Treeview",
            background=COLORS["white"],
            foreground=COLORS["text"],
            rowheight=26,
            fieldbackground=COLORS["white"],
            font=("Segoe UI", 8),
            borderwidth=0
        )
        s.configure(
            "Cargo.Treeview.Heading",
            background=COLORS["info"],
            foreground="white",
            font=("Segoe UI", 8, "bold")
        )

    # ═══════════════════════════════════════════════════════
    # UI BUILD
    # ═══════════════════════════════════════════════════════

    def _build_ui(self):
        self._build_header()
        self._build_status_bars()

        main = tk.Frame(self.root, bg=COLORS["bg"])
        main.pack(fill=tk.BOTH, expand=True, padx=10, pady=8)

        self._build_soldier_list(main)
        self._build_form_panel(main)
        self._build_card_panel(main)

        self._build_footer()

    def _build_header(self):
