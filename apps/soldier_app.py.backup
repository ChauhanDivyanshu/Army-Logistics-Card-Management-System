    # ── Middle Panel: Form ────────────────────────────────

        # ── Middle Panel: Form (SCROLLABLE) ───────────────────

    def _build_form_panel(self, parent):
        # Outer container with fixed width
        mid_container = tk.Frame(parent, bg=COLORS["bg"], width=380)
        mid_container.pack(side=tk.LEFT, fill=tk.BOTH, padx=5)
        mid_container.pack_propagate(False)

        # Canvas + Scrollbar for scrolling
        canvas = tk.Canvas(mid_container, bg=COLORS["bg"],
                           highlightthickness=0, bd=0)
        scrollbar = ttk.Scrollbar(mid_container, orient="vertical",
                                   command=canvas.yview)
        canvas.configure(yscrollcommand=scrollbar.set)

        scrollbar.pack(side=tk.RIGHT, fill=tk.Y)
        canvas.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)

        # Inner scrollable frame
        mid_frame = tk.Frame(canvas, bg=COLORS["bg"])
        canvas_window = canvas.create_window(
            (0, 0), window=mid_frame, anchor="nw"
        )

        # Update scroll region when content changes
        def _on_frame_configure(event):
            canvas.configure(scrollregion=canvas.bbox("all"))

        def _on_canvas_configure(event):
            canvas.itemconfig(canvas_window, width=event.width)

        mid_frame.bind("<Configure>", _on_frame_configure)
        canvas.bind("<Configure>", _on_canvas_configure)

        # Mouse wheel scrolling
        def _on_mousewheel(event):
            canvas.yview_scroll(int(-1 * (event.delta / 120)), "units")

        canvas.bind_all("<MouseWheel>", _on_mousewheel)

        # ═══ Soldier Form ═══
        form_box = tk.LabelFrame(
            mid_frame,
            text="  ➕  SOLDIER DETAILS  ",
            font=("Segoe UI", 10, "bold"),
            bg=COLORS["bg"], fg=COLORS["primary"],
            bd=1, relief=tk.GROOVE
        )
        form_box.pack(fill=tk.X, pady=(0, 6))

