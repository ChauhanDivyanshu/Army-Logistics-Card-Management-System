# .gitignore - Army Logistics System

# ─────────────────────────────────────────────
# PYTHON
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# ─────────────────────────────────────────────
# VIRTUAL ENVIRONMENTS
# ─────────────────────────────────────────────
venv/
env/
ENV/
.venv/

# ─────────────────────────────────────────────
# IDE / EDITOR
# ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ─────────────────────────────────────────────
# DATABASE CREDENTIALS (SECURITY!)
# ─────────────────────────────────────────────
database/db_config.py
config.ini
*.env
.env

# ─────────────────────────────────────────────
# LOGS & TEMPORARY FILES
# ─────────────────────────────────────────────
logs/
*.log
*.tmp
*.bak

# ─────────────────────────────────────────────
# DATABASE BACKUPS
# ─────────────────────────────────────────────
*.sql.bak
*.dump
backups/

# ─────────────────────────────────────────────
# WINDOWS
# ─────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─────────────────────────────────────────────
# TEST FILES (optional)
# ─────────────────────────────────────────────
test_gate.py